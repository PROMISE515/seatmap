# Public Supabase config used by the browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-side Supabase config used by TanStack Start server functions.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AMap Web Service key for nearby POI and reverse-geocoding lookups.
AMAP_WEB_SERVICE_KEY=

# AMap JS API key used by the browser map preview.
VITE_AMAP_JS_KEY=

# Lovable AI Gateway key, used for POI name translation and optionally the Stripe connector gateway.
LOVABLE_API_KEY=

# Stripe publishable key for Embedded Checkout.
# Use pk_test_... for sandbox and pk_live_... for real payments.
VITE_PAYMENTS_CLIENT_TOKEN=

# Standard Stripe secret keys. Prefer these for direct real Stripe payments.
STRIPE_SANDBOX_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=

# Optional: paste exact Stripe price IDs if you did not set lookup keys in Stripe.
# If omitted, the app uses lookup keys: travel_pass_7_price, travel_pass_15_price, travel_pass_30_price.
STRIPE_TRAVEL_PASS_7_PRICE_ID=
STRIPE_TRAVEL_PASS_15_PRICE_ID=
STRIPE_TRAVEL_PASS_30_PRICE_ID=

# Optional Lovable Stripe connector keys, kept for Lovable-managed payments.
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=

# Stripe webhook signing secrets for /api/stripe/webhook.
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=

# Canonical production origin and extra checkout return origins.
SITE_URL=http://localhost:5173
PAYMENTS_ALLOWED_RETURN_ORIGINS=http://localhost:8080
